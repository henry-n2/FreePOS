<div class="modal-header modal-header-custom">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true" style="color: white; opacity: 0.8;">&times;</button>
    <h4 class="modal-title">Inventory Adjustment - <%= item.name %></h4>
</div>

<form id="inventory-form" action="/items/inventory/<%= item._id %>" method="POST" class="form-horizontal">
    <div class="modal-body">
        <div class="form-group">
            <label class="col-sm-4 control-label">Select Location:</label>
            <div class="col-sm-8">
                <select name="location_id" class="form-control" required>
                    <% locations.forEach(loc => { %>
                        <option value="<%= loc.location_id %>"><%= loc.location_name %></option>
                    <% }); %>
                </select>
            </div>
        </div>

        <div class="form-group">
            <label class="col-sm-4 control-label">Adjustment Mode:</label>
            <div class="col-sm-8">
                <label class="radio-inline">
                    <input type="radio" name="mode" value="add" checked> Add / Subtract
                </label>
                <label class="radio-inline">
                    <input type="radio" name="mode" value="set"> Set Absolute Value
                </label>
            </div>
        </div>

        <div class="form-group">
            <label class="col-sm-4 control-label">Quantity:</label>
            <div class="col-sm-8">
                <input type="number" step="0.001" name="quantity" class="form-control" required placeholder="Use negative values to subtract">
            </div>
        </div>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
        <button type="submit" class="btn btn-primary">Save Adjustment</button>
    </div>
</form>

<script>
  $(document).ready(function() {
    $('#inventory-form').submit(function(e) {
      e.preventDefault();
      const form = $(this);
      
      $.ajax({
        url: form.attr('action'),
        type: 'POST',
        data: form.serialize(),
        dataType: 'json',
        success: function(response) {
          if (response.success) {
            show_feedback('success', response.message, 'Success');
            $('#myModal').modal('hide');
            $('#table').bootstrapTable('refresh');
          } else {
            show_feedback('danger', response.message, 'Error');
          }
        },
        error: function(err) {
          show_feedback('danger', 'Server error adjusting inventory', 'Error');
        }
      });
    });
  });
</script>
