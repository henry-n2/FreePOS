    <!-- Custom Helper Script (mimicking FreePOS manage_tables.js helpers) -->
    <script>
      // Global clock update
      setInterval(function() {
        const liveClock = document.getElementById('liveclock');
        if (liveClock) {
          liveClock.innerHTML = new Date().toLocaleString();
        }
      }, 1000);

      // Flash message alerts helper
      function show_feedback(type, message, title) {
        const alertClass = type === 'success' ? 'alert-success' : 'alert-danger';
        const alertHtml = `
          <div class="alert ${alertClass} alert-dismissible" role="alert" style="position: fixed; top: 20px; right: 20px; z-index: 9999; min-width: 300px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
            <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
            <strong>${title || 'Notification'}:</strong> ${message}
          </div>
        `;
        $('body').append(alertHtml);
        setTimeout(function() {
          $('.alert').fadeOut('slow', function() { $(this).remove(); });
        }, 3000);
      }

      // Theme toggle script
      $(document).ready(function() {
        const $themeLink = $('#bootswatch-theme');
        const $toggleBtn = $('#theme-toggle');
        const defaultTheme = '<%= typeof config !== "undefined" ? (config.theme || "flatly") : "flatly" %>';
        const currentTheme = localStorage.getItem('pos-theme') || defaultTheme;

        function applyTheme(themeName) {
          let url = `https://cdnjs.cloudflare.com/ajax/libs/bootswatch/3.4.0/${themeName}/bootstrap.min.css`;
          $themeLink.attr('href', url);
          if (themeName === 'darkly') {
            $toggleBtn.html('<i class="fa fa-sun-o"></i> Light Mode');
          } else {
            $toggleBtn.html('<i class="fa fa-moon-o"></i> Dark Mode');
          }
        }

        // Initial apply
        applyTheme(currentTheme);

        $toggleBtn.click(function(e) {
          e.preventDefault();
          let activeTheme = localStorage.getItem('pos-theme') || defaultTheme;
          let newTheme = activeTheme === 'darkly' ? defaultTheme : 'darkly';
          localStorage.setItem('pos-theme', newTheme);
          applyTheme(newTheme);
        });
      });
    </script>
</body>
</html>
