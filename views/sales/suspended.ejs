<%- include('../partial/header') %>

<div class="col-md-12">
    <div class="page-header" style="margin-top: 0;">
        <div class="row">
            <div class="col-md-6">
                <h3 style="margin: 0;"><i class="glyphicon glyphicon-list"></i> Suspended Sales</h3>
            </div>
            <div class="col-md-6 text-right">
                <a href="/sales" class="btn btn-default">
                    <span class="glyphicon glyphicon-shopping-cart"></span> Return to Register
                </a>
            </div>
        </div>
    </div>

    <div class="panel panel-default" style="border-radius: 8px;">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Invoice Number</th>
                    <th>Customer</th>
                    <th>Employee</th>
                    <th>Comment</th>
                    <th style="width: 150px; text-align: center;">Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if (sales.length === 0) { %>
                    <tr>
                        <td colspan="6" class="text-center text-muted" style="padding: 30px;">No suspended sales found.</td>
                    </tr>
                <% } else { %>
                    <% sales.forEach(sale => { %>
                        <tr>
                            <td><%= sale.sale_time.toLocaleString() %></td>
                            <td><%= sale.invoice_number %></td>
                            <td><%= sale.customer ? `${sale.customer.first_name} ${sale.customer.last_name}` : 'Walk-in Customer' %></td>
                            <td><%= sale.employee ? `${sale.employee.first_name} ${sale.employee.last_name}` : 'Unknown' %></td>
                            <td><%= sale.comment %></td>
                            <td style="text-align: center;">
                                <a href="/sales/unsuspend/<%= sale._id %>" class="btn btn-xs btn-primary">
                                    <i class="glyphicon glyphicon-open"></i> Unsuspend
                                </a>
                            </td>
                        </tr>
                    <% }); %>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<%- include('../partial/footer') %>
