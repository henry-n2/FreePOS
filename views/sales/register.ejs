<%- include('../partial/header') %>

<style>
    .product-card {
        cursor: pointer;
        padding: 10px;
        border-radius: 8px;
        border: 1px solid #ddd;
        transition: transform 0.15s, box-shadow 0.15s;
        height: 155px;
        margin-bottom: 0;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        background: #fff;
    }
    .product-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 10px rgba(0,0,0,0.12);
        border-color: #2c3e50 !important;
    }
    .category-filters::-webkit-scrollbar {
        height: 4px;
    }
    .category-filters::-webkit-scrollbar-thumb {
        background: #ccc;
        border-radius: 4px;
    }
    .category-btn {
        border-radius: 20px;
        margin-right: 6px;
        font-weight: 500;
        transition: all 0.2s;
    }
    .inline-edit-input {
        width: 100%;
        height: 26px;
        padding: 2px 5px;
        font-size: 12px;
        border-radius: 4px;
        border: 1px solid #ccc;
    }
</style>

<div class="col-md-7">
    <% if (feedback) { %>
        <div class="alert alert-<%= feedback.type %> alert-dismissible" role="alert" style="border-radius: 8px;">
            <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
            <strong>Notification:</strong> <%= feedback.message %>
        </div>
    <% } %>

    <!-- Find Item Search Box & Category Filters -->
    <div class="panel panel-default" style="border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.05); margin-bottom: 15px;">
        <div class="panel-body" style="padding: 15px;">
            <form action="/sales/add" method="POST" class="form-horizontal" id="add-item-form">
                <div class="input-group">
                    <span class="input-group-addon" style="background: white; border-right: none;">
                        <i class="glyphicon glyphicon-search" style="color: #888;"></i>
                    </span>
                    <input type="text" id="item-lookup" class="form-control" style="border-left: none; box-shadow: none;" placeholder="Search by name, category, or scan SKU/Barcode...">
                    <input type="hidden" name="item_id" id="selected-item-id">
                    <span class="input-group-btn">
                        <button type="button" class="btn btn-default" id="webcam-scan-btn" title="Scan via Webcam">
                            <span class="glyphicon glyphicon-camera"></span> Webcam Scan
                        </button>
                        <button type="submit" class="btn btn-primary" style="font-weight: bold; border-top-right-radius: 4px; border-bottom-right-radius: 4px;">Add to Cart</button>
                    </span>
                </div>
            </form>
            
            <!-- Category Scroll list -->
            <%
              const uniqueCategories = [...new Set(items.map(item => item.category))].filter(Boolean);
            %>
            <div class="category-filters" style="margin-top: 15px; white-space: nowrap; overflow-x: auto; padding-bottom: 6px;">
                <button type="button" class="btn btn-sm btn-primary filter-cat-btn category-btn" data-category="all">All Items</button>
                <% uniqueCategories.forEach(cat => { %>
                    <button type="button" class="btn btn-sm btn-default filter-cat-btn category-btn" data-category="<%= cat %>"><%= cat %></button>
                <% }); %>
            </div>
        </div>
    </div>

    <!-- Clickable Product Card Grid -->
    <div class="row" id="product-grid" style="max-height: 480px; overflow-y: auto; padding-right: 5px; margin-bottom: 20px;">
        <% if (items.length === 0) { %>
            <div class="col-md-12 text-center text-muted" style="padding: 40px;">
                <i class="glyphicon glyphicon-tags" style="font-size: 48px; color: #ddd; margin-bottom: 15px;"></i>
                <p>No products available. Add items in Items Management first.</p>
            </div>
        <% } else { %>
            <% items.forEach(item => { %>
                <div class="col-xs-6 col-sm-4 col-md-3 product-card-container" data-category="<%= item.category %>" data-name="<%= item.name.toLowerCase() %>" data-sku="<%= (item.item_number || '').toLowerCase() %>" style="margin-bottom: 15px;">
                    <div class="thumbnail product-card" onclick="document.getElementById('quick-add-form-<%= item._id %>').submit()">
                        
                        <form id="quick-add-form-<%= item._id %>" action="/sales/add" method="POST" style="display:none;">
                            <input type="hidden" name="item_id" value="<%= item._id %>">
                            <input type="hidden" name="quantity" value="1">
                        </form>

                        <div class="text-center" style="height: 55px; display: flex; align-items: center; justify-content: center; margin-bottom: 5px;">
                            <% if (item.pic_filename) { %>
                                <img src="/uploads/<%= item.pic_filename %>" style="max-height: 55px; max-width: 100%; object-fit: contain; border-radius: 4px;">
                            <% } else { %>
                                <div style="font-size: 28px; color: #ddd;"><i class="glyphicon glyphicon-picture"></i></div>
                            <% } %>
                        </div>
                        
                        <div style="flex-grow: 1; display: flex; flex-direction: column; justify-content: flex-end;">
                            <h5 style="margin: 0 0 2px 0; font-size: 11px; font-weight: bold; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; text-align: center; color: #333;" title="<%= item.name %>">
                                <%= item.name %>
                            </h5>
                            <p style="margin: 0; font-size: 10px; color: #888; text-align: center; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= item.category %></p>
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 5px;">
                                <span class="label label-primary" style="font-size: 10px; background-color: #2c3e50;"><%= config.currency_symbol || '₹' %><%= item.unit_price.toFixed(2) %></span>
                                <% 
                                  const totalQty = item.quantities ? item.quantities.reduce((sum, q) => sum + (q.quantity || 0), 0) : 0;
                                  const isLowStock = totalQty <= (item.reorder_level || 0);
                                  const stockClass = isLowStock ? 'label-danger' : 'label-success';
                                %>
                                <span class="label <%= stockClass %>" style="font-size: 8px;">Stock: <%= totalQty %></span>
                            </div>
                        </div>
                    </div>
                </div>
            <% }); %>
        <% } %>
    </div>
</div>

<!-- Right Column: Cart, Customer Selection, Payments & Checkout -->
<div class="col-md-5">
    <!-- Cart Details panel -->
    <div class="panel panel-default" style="border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.05);">
        <div class="panel-heading" style="background: #2c3e50; color: white; border-top-left-radius: 8px; border-top-right-radius: 8px; font-weight: bold;">
            <i class="glyphicon glyphicon-shopping-cart"></i> Cart Items
        </div>
        <div class="table-responsive" style="max-height: 250px; overflow-y: auto;">
            <table class="table table-striped table-hover" id="register-cart-table" style="margin-bottom:0;">
                <thead>
                    <tr>
                        <th style="width: 40px; text-align: center;">Del</th>
                        <th>Item</th>
                        <th style="width: 70px;">Price</th>
                        <th style="width: 60px;">Qty</th>
                        <th style="width: 50px;">Disc%</th>
                        <th style="width: 80px; text-align: right;">Total</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (cart.items.length === 0) { %>
                        <tr>
                            <td colspan="6" class="text-center text-muted" style="padding: 25px;">Cart is Empty. Click products or search above.</td>
                        </tr>
                    <% } else { %>
                        <% cart.items.forEach((item, index) => { 
                           const itemTotal = item.unit_price * item.quantity * (1 - (item.discount_percent || 0) / 100);
                        %>
                            <tr>
                                <td style="text-align: center; vertical-align: middle;">
                                    <a href="/sales/delete_item/<%= index %>" class="text-danger" style="font-size: 14px;"><i class="glyphicon glyphicon-remove-circle"></i></a>
                                </td>
                                <td style="vertical-align: middle; font-size: 11px;">
                                    <strong><%= item.name %></strong>
                                    <% if (item.is_serialized) { %>
                                        <br><input type="text" name="serialnumber" value="<%= item.serialnumber %>" class="inline-edit-input inline-edit" data-index="<%= index %>" placeholder="S/N" style="margin-top:2px;">
                                    <% } %>
                                </td>
                                <td style="vertical-align: middle;">
                                    <input type="number" name="unit_price" step="0.01" value="<%= item.unit_price %>" class="inline-edit-input inline-edit" data-index="<%= index %>">
                                </td>
                                <td style="vertical-align: middle;">
                                    <input type="number" name="quantity" step="0.001" value="<%= item.quantity %>" class="inline-edit-input inline-edit" data-index="<%= index %>">
                                </td>
                                <td style="vertical-align: middle;">
                                    <input type="number" name="discount_percent" step="1" value="<%= item.discount_percent %>" class="inline-edit-input inline-edit" data-index="<%= index %>">
                                </td>
                                <td style="text-align: right; font-weight: bold; vertical-align: middle; font-size: 11px;">
                                    <%= config.currency_symbol || '₹' %><%= itemTotal.toFixed(2) %>
                                </td>
                            </tr>
                        <% }); %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Stock Location & Customer Selector -->
    <div class="row">
        <div class="col-xs-6" style="padding-right: 5px;">
            <div class="panel panel-default" style="border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.05); margin-bottom: 12px;">
                <div class="panel-body" style="padding: 10px;">
                    <form action="/sales/location" method="POST" id="location-form">
                        <label style="font-size: 11px; margin-bottom: 2px;">Stock Location:</label>
                        <select name="location_id" class="form-control input-sm" onchange="this.form.submit()">
                            <% locations.forEach(loc => { %>
                                <option value="<%= loc.location_id %>" <%= activeLocation === loc.location_id ? 'selected' : '' %>><%= loc.location_name %></option>
                            <% }); %>
                        </select>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-xs-6" style="padding-left: 5px;">
            <div class="panel panel-default" style="border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.05); margin-bottom: 12px;">
                <div class="panel-body" style="padding: 10px;">
                    <label style="font-size: 11px; margin-bottom: 2px;"><i class="glyphicon glyphicon-user"></i> Customer:</label>
                    <% if (!customer) { %>
                        <form action="/sales/select_customer" method="POST" id="customer-select-form">
                            <div class="input-group">
                                <input type="text" id="customer-lookup" class="form-control input-sm" placeholder="Search customer...">
                                <input type="hidden" name="customer_id" id="selected-customer-id">
                                <span class="input-group-btn">
                                    <button type="button" class="btn btn-default btn-sm" data-toggle="modal" data-target="#quickCustomerModal" title="Quick Add Customer">
                                        <span class="glyphicon glyphicon-plus"></span>
                                    </button>
                                </span>
                            </div>
                        </form>
                    <% } else { %>
                        <div style="font-size: 11px; position: relative; padding-right: 25px;">
                            <strong><%= customer.first_name %> <%= customer.last_name %></strong>
                            <div class="text-muted" style="font-size: 10px;"><%= customer.company_name || 'Individual' %> (Disc: <%= customer.discount_percent %>%)</div>
                            <a href="/sales/remove_customer" class="text-danger" style="position: absolute; right: 0; top: 2px; font-size: 14px;" title="Remove Customer"><i class="glyphicon glyphicon-remove-sign"></i></a>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Totals Display -->
    <div class="panel panel-default" style="border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.05); margin-bottom: 12px;">
        <ul class="list-group" style="margin-bottom:0;">
            <li class="list-group-item" style="padding: 6px 12px; font-size: 11px;">
                Subtotal:
                <strong class="pull-right"><%= config.currency_symbol || '₹' %><%= subtotal.toFixed(2) %></strong>
            </li>
            <li class="list-group-item" style="padding: 6px 12px; font-size: 11px;">
                Tax:
                <strong class="pull-right"><%= config.currency_symbol || '₹' %><%= taxTotal.toFixed(2) %></strong>
            </li>
            <li class="list-group-item" style="background-color: #fcfcfc; padding: 8px 12px; font-size: 15px; font-weight: bold;">
                Total Due:
                <strong class="pull-right text-primary"><%= config.currency_symbol || '₹' %><%= total.toFixed(2) %></strong>
            </li>
        </ul>
    </div>

    <!-- Payments Section -->
    <div class="panel panel-default" style="border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.05); margin-bottom: 12px;">
        <div class="panel-heading" style="padding: 6px 12px; background: #eee; font-weight: bold; font-size: 11px;">
            <i class="fa fa-inr" aria-hidden="true"></i> Payments
        </div>
        <div class="panel-body" style="padding: 10px;">
            <% if (cart.payments.length > 0) { %>
                <table class="table table-condensed table-striped" style="font-size: 11px; margin-bottom: 8px;">
                    <tbody>
                        <% cart.payments.forEach((p, idx) => { %>
                            <tr>
                                <td><%= p.payment_type %></td>
                                <td style="text-align: right; font-weight: bold;">₹<%= p.payment_amount.toFixed(2) %></td>
                                <td style="text-align: center; width: 20px;"><a href="/sales/delete_payment/<%= idx %>" class="text-danger"><i class="glyphicon glyphicon-remove"></i></a></td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            <% } %>

            <form action="/sales/add_payment" method="POST" class="form-inline text-center">
                <div class="form-group" style="width: 48%; margin-right: 2%;">
                    <select name="payment_type" class="form-control input-sm" style="width: 100%;">
                        <option value="Cash">Cash</option>
                        <option value="Check">Check</option>
                        <option value="Debit Card">Debit Card</option>
                        <option value="Credit Card">Credit Card</option>
                        <option value="Gift Card">Gift Card</option>
                        <option value="Points">Points/Rewards</option>
                    </select>
                </div>
                <div class="form-group" style="width: 48%;">
                    <div class="input-group input-group-sm" style="width: 100%;">
                        <span class="input-group-addon"><%= config.currency_symbol || '₹' %></span>
                        <input type="number" name="payment_amount" step="0.01" class="form-control" placeholder="Amount" value="<%= amountDue > 0 ? amountDue.toFixed(2) : '0.00' %>" required>
                    </div>
                </div>
                <button type="submit" class="btn btn-default btn-xs btn-block" style="margin-top: 6px;">Add Payment</button>
            </form>
        </div>
    </div>

    <!-- Finalization / Checkout Buttons -->
    <% if (cart.items.length > 0) { %>
        <div class="panel panel-default" style="border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.05); border-color: #d6e9c6;">
            <div class="panel-body" style="padding: 12px;">
                <form action="/sales/complete" method="POST" id="complete-sale-form">
                    <div class="form-group" style="margin-bottom: 8px;">
                        <textarea name="comment" class="form-control input-sm" rows="1" placeholder="Comments..."></textarea>
                    </div>
                    
                    <button type="submit" class="btn btn-success btn-block" style="font-weight: bold; font-size: 14px; padding: 8px 12px;">
                        <span class="glyphicon glyphicon-ok"></span> Make Bill / Print
                    </button>
                </form>
                
                <div class="row" style="margin-top: 8px;">
                    <div class="col-xs-6" style="padding-right: 4px;">
                        <form action="/sales/suspend" method="POST">
                            <button type="submit" class="btn btn-warning btn-xs btn-block">Suspend Sale</button>
                        </form>
                    </div>
                    <div class="col-xs-6" style="padding-left: 4px;">
                        <form action="/sales/cancel" method="POST">
                            <button type="submit" class="btn btn-danger btn-xs btn-block" onclick="return confirm('Are you sure you want to clear this sale?')">Clear Cart</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    <% } %>
    <a href="/sales/suspended" class="btn btn-default btn-sm btn-block" style="border-radius: 6px;"><i class="glyphicon glyphicon-list"></i> Suspended Sales List</a>
</div>

<!-- Quick Add Customer Modal -->
<div class="modal fade" id="quickCustomerModal" tabindex="-1" role="dialog" aria-labelledby="quickCustomerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content" style="border-radius: 8px;">
            <div class="modal-header modal-header-custom" style="border-top-left-radius: 8px; border-top-right-radius: 8px;">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true" style="color: white; opacity: 0.8;">&times;</button>
                <h4 class="modal-title" id="quickCustomerModalLabel"><i class="glyphicon glyphicon-user"></i> Quick Add Customer</h4>
            </div>
            <form action="/sales/quick_add_customer" method="POST">
                <div class="modal-body">
                    <div class="form-group">
                        <label class="control-label">First Name *</label>
                        <input type="text" name="first_name" class="form-control input-sm" required placeholder="First name">
                    </div>
                    <div class="form-group">
                        <label class="control-label">Last Name *</label>
                        <input type="text" name="last_name" class="form-control input-sm" required placeholder="Last name">
                    </div>
                    <div class="form-group">
                        <label class="control-label">Phone Number</label>
                        <input type="text" name="phone_number" class="form-control input-sm" placeholder="Phone number">
                    </div>
                    <div class="form-group">
                        <label class="control-label">Email Address</label>
                        <input type="email" name="email" class="form-control input-sm" placeholder="Email address">
                    </div>
                    <div class="form-group">
                        <label class="control-label">Company Name</label>
                        <input type="text" name="company_name" class="form-control input-sm" placeholder="Company name">
                    </div>
                </div>
                <div class="modal-footer" style="padding: 10px 15px;">
                    <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Add & Select</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Webcam Barcode Scanner Modal -->
<div class="modal fade" id="webcamModal" tabindex="-1" role="dialog" aria-labelledby="webcamModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content" style="border-radius: 8px;">
            <div class="modal-header modal-header-custom" style="border-top-left-radius: 8px; border-top-right-radius: 8px;">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true" style="color: white; opacity: 0.8;">&times;</button>
                <h4 class="modal-title" id="webcamModalLabel"><i class="glyphicon glyphicon-camera"></i> Webcam Barcode Scanner</h4>
            </div>
            <div class="modal-body text-center">
                <div id="reader" style="width: 100%; max-width: 500px; margin: 0 auto; border-radius: 8px; overflow: hidden; background: #eee;"></div>
                <p class="help-block" style="margin-top: 15px;">Hold the barcode steady and well-lit in front of the camera.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<%- include('../partial/footer') %>

<script src="https://unpkg.com/html5-qrcode"></script>
<script>
  $(document).ready(function() {
    // Autocomplete for searching items
    $('#item-lookup').autocomplete({
      source: '/items/suggest',
      minLength: 2,
      select: function(event, ui) {
        $('#selected-item-id').val(ui.item.value);
        $('#add-item-form').submit();
        return false;
      }
    });

    // Realtime search filter on product grid
    $('#item-lookup').on('input', function() {
      const term = $(this).val().toLowerCase();
      const activeCat = $('.filter-cat-btn.btn-primary').data('category');
      
      $('.product-card-container').each(function() {
        const name = $(this).data('name');
        const sku = $(this).data('sku').toString();
        const cat = $(this).data('category');
        
        const matchesSearch = name.includes(term) || sku.includes(term);
        const matchesCategory = activeCat === 'all' || cat === activeCat;
        
        if (matchesSearch && matchesCategory) {
          $(this).show();
        } else {
          $(this).hide();
        }
      });
    });

    // Category button filter
    $('.filter-cat-btn').click(function(e) {
      e.preventDefault();
      $('.filter-cat-btn').removeClass('btn-primary').addClass('btn-default');
      $(this).removeClass('btn-default').addClass('btn-primary');
      
      const cat = $(this).data('category');
      const term = $('#item-lookup').val().toLowerCase();
      
      $('.product-card-container').each(function() {
        const itemCat = $(this).data('category');
        const name = $(this).data('name');
        const sku = $(this).data('sku').toString();
        
        const matchesCategory = cat === 'all' || itemCat === cat;
        const matchesSearch = name.includes(term) || sku.includes(term);
        
        if (matchesCategory && matchesSearch) {
          $(this).show();
        } else {
          $(this).hide();
        }
      });
    });

    // Autocomplete for customer selection
    $('#customer-lookup').autocomplete({
      source: '/customers/suggest',
      minLength: 2,
      select: function(event, ui) {
        $('#selected-customer-id').val(ui.item.value);
        $('#customer-select-form').submit();
        return false;
      }
    });

    // Inline edit quantity / price / discount
    $('.inline-edit').change(function() {
      const field = $(this).attr('name');
      const value = $(this).val();
      const index = $(this).data('index');
      
      const form = $('<form action="/sales/edit_item/' + index + '" method="POST"></form>');
      form.append(`<input type="hidden" name="${field}" value="${value}">`);
      
      $('body').append(form);
      form.submit();
    });

    // Webcam scanning logic using Html5Qrcode
    let html5QrcodeScanner = null;

    $('#webcam-scan-btn').click(function(e) {
      e.preventDefault();
      $('#webcamModal').modal('show');
      
      // Delay initialization slightly to let modal show completely
      setTimeout(() => {
        html5QrcodeScanner = new Html5Qrcode("reader");
        const config = { fps: 10, qrbox: { width: 300, height: 150 } };
        
        html5QrcodeScanner.start(
          { facingMode: "environment" }, 
          config,
          (decodedText, decodedResult) => {
            // Success scanning barcode
            $('#selected-item-id').val(decodedText);
            $('#item-lookup').val(decodedText);
            
            // Stop camera and submit
            html5QrcodeScanner.stop().then(() => {
              $('#webcamModal').modal('hide');
              $('#add-item-form').submit();
            }).catch(err => {
              console.error(err);
              $('#webcamModal').modal('hide');
              $('#add-item-form').submit();
            });
          },
          (errorMessage) => {
            // silent frame scanning parsing errors
          }
        ).catch(err => {
          console.error("Camera start error", err);
          alert("Unable to access camera: " + err);
          $('#webcamModal').modal('hide');
        });
      }, 500);
    });

    $('#webcamModal').on('hide.bs.modal', function () {
      if (html5QrcodeScanner && html5QrcodeScanner.isScanning) {
        html5QrcodeScanner.stop().catch(err => console.error("Error stopping camera stream", err));
      }
    });

    // Support hardware barcode scanners that keypress barcode SKU and immediately trigger submit/enter
    $('#add-item-form').submit(function(e) {
      const selectedId = $('#selected-item-id').val();
      const lookupText = $('#item-lookup').val();
      
      // If no item was selected from autocomplete but we scanned a barcode SKU into input
      if (!selectedId && lookupText) {
        $('#selected-item-id').val(lookupText);
      }
    });
  });
</script>
